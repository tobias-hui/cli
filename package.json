{
  "name": "pimx-cli",
  "version": "1.0.11",
  "description": "Multi-provider media generation CLI (MiniMax + PiAPI)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "pimx": "dist/pimx.mjs"
  },
  "files": [
    "dist/pimx.mjs"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun run build.ts",
    "build:dev": "bun build src/main.ts --outfile dist/pimx.mjs --target node --minify --define \"process.env.CLI_VERSION='1.0.4'\" && printf '#!/usr/bin/env node\\n' | cat - dist/pimx.mjs > dist/tmp && mv dist/tmp dist/pimx.mjs && chmod +x dist/pimx.mjs",
    "prepublishOnly": "bun run build",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "latest",
    "eslint": "^9.24.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  }
}
